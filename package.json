{
  "$schema": "https://json.schemastore.org/package",
  "name": "o-tiling",
  "version": "2.9.12",
  "description": "Auto-tiling extension for GNOME Shell with 'Aura' focus border, customizable workspace overview styling, and theme consistency.",
  "author": "oliwebd",
  "type": "module",
  "scripts": {
    "build": "tsc && prettier --write 'dist/**/*.js' && node scripts/format-dist.mjs",
    "lint": "eslint src",
    "type-check": "tsc --noEmit",
    "deploy": "pnpm run lint && pnpm run type-check && pnpm run build",
    "lint:dist": "../GER/ego-lint ./dist",
    "shexli": "make shexli",
    "log": "journalctl -f -o cat /usr/bin/gnome-shell | grep o-tiling",
    "local-install": "make install"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@girs/gjs": "4.0.0-rc.13",
    "@girs/gnome-shell": "^50.0.0",
    "@types/node": "^25.6.2",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "ts-morph": "^28.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  },
  "packageManager": "pnpm@11.11.0+sha512.4463f65fd80ed80d69bc1d4bf163ee94f605c7380fc318bb5b2ebe15f8cd12d49c51a4d59e951b401e764d3b6ca751cbf51bc50ed7001a6bcb4935e684c34882"
}
