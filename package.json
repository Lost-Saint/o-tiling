{
  "$schema": "https://json.schemastore.org/package",
  "name": "o-tiling",
  "version": "2.4.4",
  "description": "Window auto-tiling engine for GNOME Shell.",
  "author": "oliwebd",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "lint": "eslint src",
    "type-check": "tsc --noEmit",
    "deploy": "pnpm run lint && pnpm run type-check && pnpm run build",
    "debug": "bash scripts/debug.sh"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@girs/gjs": "latest",
    "@girs/gnome-shell": "latest",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "eslint": "^9.21.0",
    "ts-morph": "^28.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0"
  }
}